# Gemini API Configuration
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Cloudinary Configuration (前端使用)
# Get your credentials from: https://cloudinary.com/console
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Airtable Configuration (後端使用)
# Get your API key from: https://airtable.com/account
# Base ID from your Airtable base URL
AIRTABLE_API_KEY=your_airtable_api_key
AIRTABLE_BASE_ID=your_airtable_base_id
AIRTABLE_TABLE_NAME=your_table_name

# n8n Webhook Configuration (後端使用)
# Your n8n webhook URL for image processing
N8N_WEBHOOK_URL=your_n8n_webhook_url

# 後端 API 環境變數範例
# 複製此檔案為 .env.local 並填入實際的值

# ===========================================
# 伺服器設定
# ===========================================
PORT=4000

# ===========================================
# CORS 設定 - 前端 URL
# ===========================================
# Main 分支前端 URL (請更新為實際的 Zeabur URL)
FRONTEND_URL_MAIN=https://your-main-frontend.zeabur.app

# Development 分支前端 URL (請更新為實際的 Zeabur URL)
FRONTEND_URL_DEV=https://your-dev-frontend.zeabur.app

# ===========================================
# Airtable 資料庫設定
# ===========================================
AIRTABLE_API_KEY=your_airtable_personal_access_token
AIRTABLE_BASE_ID=your_airtable_base_id
AIRTABLE_TABLE_NAME=Students

# ===========================================
# n8n Webhook 設定
# ===========================================
N8N_WEBHOOK_URL=your_n8n_webhook_url

# ===========================================
# 選填環境變數
# ===========================================
# Gemini API (後端不需要，前端使用)
# GEMINI_API_KEY=your_gemini_api_key

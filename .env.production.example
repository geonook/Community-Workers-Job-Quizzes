# 前端生產環境配置
# 在 Zeabur 前端服務的環境變數中設定以下內容：

# 後端 API 基礎 URL（請替換為實際的後端服務 URL）
VITE_API_BASE_URL=https://your-backend-api.zeabur.app

# Cloudinary 配置（前端直接上傳）
# ⚠️ 請填入你自己的 Cloudinary cloud name 和 unsigned upload preset，
# ⚠️ 不要把實際值 commit 到這個 example 檔。
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset
